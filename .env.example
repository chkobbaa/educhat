# Database (optional: local sqlite-compatible file by default)
TURSO_DATABASE_URL=file:educhat.db
TURSO_AUTH_TOKEN=

# Realtime websocket
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WS_PORT=3001

# Web Push (required to enable push notifications)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bahroun.me
